---
import type { Faq } from '../lib/data';

interface Props {
  faqs: Faq[];
  heading?: string;
  id?: string;
}
const { faqs, heading = 'Frequently asked questions', id = 'faq' } = Astro.props;
---

<section aria-labelledby={`${id}-heading`}>
  <h2 id={`${id}-heading`} class="text-2xl font-bold text-ink">{heading}</h2>
  <div class="mt-6 space-y-6 prose-readable">
    {
      faqs.map((faq) => (
        <div>
          <h3 class="text-base font-semibold text-ink">{faq.question}</h3>
          <p class="mt-2 leading-relaxed text-muted">{faq.answer}</p>
        </div>
      ))
    }
  </div>
</section>
