---
import { categories } from '../lib/data';
import { categoryPath } from '../lib/utils';
import { SITE } from '../site.config';

const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-line bg-surface-soft">
  <div class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div class="lg:col-span-2">
        <p class="text-base font-bold text-ink">{SITE.name}</p>
        <p class="mt-2 max-w-sm text-sm leading-relaxed text-muted">
          {SITE.description}
        </p>
      </div>

      <nav aria-label="Browse">
        <p class="text-sm font-semibold text-ink">Browse</p>
        <ul class="mt-3 space-y-2 text-sm">
          {
            categories.map((c) => (
              <li>
                <a
                  class="text-muted hover:text-brand-strong"
                  href={categoryPath(c)}
                >
                  {c.name}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <nav aria-label="About">
        <p class="text-sm font-semibold text-ink">About</p>
        <ul class="mt-3 space-y-2 text-sm">
          <li>
            <a class="text-muted hover:text-brand-strong" href="/about/"
              >About this directory</a
            >
          </li>
          <li>
            <a class="text-muted hover:text-brand-strong" href="/how-we-verify/"
              >How we verify listings</a
            >
          </li>
          <li>
            <a class="text-muted hover:text-brand-strong" href="/sensory-gear/"
              >Sensory gear we recommend</a
            >
          </li>
          <li>
            <a
              class="text-muted hover:text-brand-strong"
              href="/sensory-friendly-fireworks/">Sensory-friendly fireworks guide</a
            >
          </li>
          <li>
            <a class="text-muted hover:text-brand-strong" href="/support/"
              >Support this site</a
            >
          </li>
          <li>
            <a class="text-muted hover:text-brand-strong" href="/privacy/"
              >Privacy &amp; disclaimer</a
            >
          </li>
          <li>
            <a
              class="text-muted hover:text-brand-strong"
              href={`mailto:${SITE.contactEmail}`}>Suggest a place</a
            >
          </li>
        </ul>
      </nav>
    </div>

    <div class="mt-8 border-t border-line pt-6 text-xs leading-relaxed text-muted">
      <p>
        © {year} {SITE.name}. Listings are provided for information only — always
        confirm hours, pricing, and accommodations directly with each business
        before you visit.
      </p>
    </div>
  </div>
</footer>
