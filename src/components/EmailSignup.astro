---
/**
 * "Get sensory-friendly events near you" email capture.
 *
 * When SITE.newsletter.actionUrl is set, the form subscribes the visitor via a
 * client-side fetch to the provider (Kit/ConvertKit tag-subscribe), showing an
 * inline thank-you without leaving the page. With JS disabled — or no provider
 * configured — it falls back to opening a pre-filled email to the contact
 * address, so it always does something sensible. Pass `cityName` to personalise.
 */
import { SITE } from '../site.config';

interface Props {
  /** City to name in the heading, e.g. "Dallas". Omit for a generic prompt. */
  cityName?: string;
}
const { cityName } = Astro.props;

const endpoint = SITE.newsletter.actionUrl.trim();
const publicKey = SITE.newsletter.publicKey.trim();
const emailField = SITE.newsletter.emailField || 'email';
const configured = endpoint.length > 0;

// No-JS / not-configured fallback: open a pre-addressed email.
const mailtoAction = `mailto:${SITE.contactEmail}?subject=${encodeURIComponent(
  'Sign me up for sensory-friendly events',
)}`;

const heading = cityName
  ? `Get sensory-friendly events near ${cityName}`
  : 'Get sensory-friendly events near you';
---

<section
  aria-labelledby="signup-heading"
  class="mt-12 rounded-card border border-brand-soft bg-brand-soft/50 p-6 sm:p-8"
>
  <div class="max-w-2xl">
    <h2 id="signup-heading" class="text-2xl font-bold text-ink">{heading}</h2>
    <p class="mt-2 leading-relaxed text-muted">
      New sensory-friendly screenings, quiet hours, and family events land all the
      time. Get an occasional email with what's coming up near you — no spam, and
      you can unsubscribe in one click.
    </p>

    <form
      class="mt-5 flex flex-col gap-3 sm:flex-row"
      action={mailtoAction}
      method="post"
      enctype="text/plain"
      {...configured
        ? {
            'data-endpoint': endpoint,
            'data-key': publicKey,
            'data-field': emailField,
          }
        : {}}
    >
      <label class="sr-only" for="signup-email">Email address</label>
      <input
        id="signup-email"
        type="email"
        name="email"
        required
        autocomplete="email"
        placeholder="you@example.com"
        class="w-full flex-1 rounded-lg border border-line bg-surface px-4 py-2.5 text-ink placeholder:text-muted/70 focus:border-brand focus:outline-none"
      />
      {/* Honeypot: real people leave this blank; bots tend to fill it. */}
      <input
        type="text"
        name="hp_website"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
        class="hidden"
      />
      <button
        type="submit"
        class="rounded-lg bg-brand px-5 py-2.5 font-semibold text-white transition-colors hover:bg-brand-strong"
      >
        Notify me
      </button>
    </form>

    <p
      data-status
      hidden
      role="status"
      class="mt-4 rounded-lg bg-surface px-4 py-3 text-sm font-medium text-brand-strong"
    >
      ✓ You're on the list! Watch your inbox for upcoming sensory-friendly events.
    </p>

    <p class="mt-3 text-xs text-muted">
      We use your email only to send sensory-friendly event updates. Read our{' '}
      <a class="link-underline hover:text-brand-strong" href="/privacy/">privacy note</a>.
    </p>
  </div>
</section>

<script>
  function wire(form: HTMLFormElement) {
    const endpoint = form.dataset.endpoint;
    if (!endpoint) return; // not configured → leave the mailto fallback alone
    const key = form.dataset.key || '';
    const field = form.dataset.field || 'email';
    const status = form.parentElement?.querySelector('[data-status]') as HTMLElement | null;
    const hp = form.querySelector('input[name="hp_website"]') as HTMLInputElement | null;
    const emailInput = form.querySelector('input[type="email"]') as HTMLInputElement | null;
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (hp && hp.value) return; // bot filled the honeypot
      const email = emailInput?.value.trim();
      if (!email || !btn) return;
      btn.disabled = true;
      const original = btn.textContent;
      btn.textContent = 'Subscribing…';
      try {
        const body = new URLSearchParams();
        if (key) body.set('api_key', key);
        body.set(field, email);
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body,
        });
        if (!res.ok) throw new Error(String(res.status));
        form.hidden = true;
        if (status) status.hidden = false;
      } catch {
        btn.disabled = false;
        btn.textContent = original;
        if (status) {
          status.hidden = false;
          status.textContent = "Hmm, that didn't go through — please try again.";
        }
      }
    });
  }
  document
    .querySelectorAll('form[data-endpoint]')
    .forEach((f) => wire(f as HTMLFormElement));
</script>
