---
import BaseLayout from '../layouts/BaseLayout.astro';
import { categories } from '../lib/data';
import { categoryPath, formatTitle } from '../lib/utils';

const featured = categories[0];
---

<BaseLayout
  title={formatTitle('Page not found')}
  description="The page you were looking for could not be found."
  noindex={true}
>
  <div class="mx-auto max-w-3xl px-4 py-20 text-center sm:px-6">
    <p class="text-sm font-semibold uppercase tracking-wide text-brand-strong">
      404
    </p>
    <h1 class="mt-3 text-3xl font-bold tracking-tight text-ink sm:text-4xl">
      We couldn't find that page
    </h1>
    <p class="mt-4 text-lg leading-relaxed text-muted">
      It may have moved, or the link may be incomplete. Try starting from one of
      these instead.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <a
        href="/"
        class="inline-block rounded-lg bg-brand px-5 py-2.5 font-semibold text-white transition-colors hover:bg-brand-strong"
      >
        Go to the homepage
      </a>
      {
        featured && (
          <a
            href={categoryPath(featured)}
            class="link-underline inline-block px-2 py-2.5 font-semibold text-brand-strong"
          >
            Browse {featured.name}
          </a>
        )
      }
    </div>
  </div>
</BaseLayout>
