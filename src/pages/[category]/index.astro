---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Faq from '../../components/Faq.astro';
import {
  categories,
  getCitiesWithCategory,
  type Category,
} from '../../lib/data';
import {
  absoluteUrl,
  categoryPath,
  cityHubPath,
  cityPath,
  formatTitle,
  truncate,
} from '../../lib/utils';
import { breadcrumbSchema, faqSchema, itemListSchema } from '../../lib/seo';

interface Props {
  category: Category;
}

export function getStaticPaths() {
  return categories.map((category) => ({
    params: { category: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const site = Astro.site;

const entries = getCitiesWithCategory(category.slug);
const dedicated = entries.filter((e) => e.qualifies);
const hubOnly = entries.filter((e) => !e.qualifies && e.hubQualifies);

const path = categoryPath(category);
const title = `Sensory-Friendly ${category.shortLabel}`;
const description = truncate(
  `${category.name} for kids, organized by city — with the sensory details, ` +
    `schedules, and accommodations that matter listed up front.`,
  160,
);

const crumbs = [
  { name: 'Home', url: absoluteUrl('/', site) },
  { name: category.name, url: absoluteUrl(path, site) },
];

const jsonLd = [
  breadcrumbSchema(crumbs),
  itemListSchema(
    `${category.name} — cities`,
    entries.map((entry) => ({
      name: `${entry.city.city}, ${entry.city.stateAbbr}`,
      url: absoluteUrl(
        entry.qualifies ? cityPath(category, entry.city) : cityHubPath(entry.city),
        site,
      ),
    })),
  ),
  faqSchema(category.faqs),
];
---

<BaseLayout
  title={formatTitle(title)}
  description={description}
  canonicalPath={path}
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-5xl px-4 py-8 sm:px-6">
    <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: category.name }]} />

    <header class="mt-6 max-w-3xl">
      <h1 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">
        {category.name}
      </h1>
      <p class="mt-3 text-lg font-medium text-brand-strong">{category.tagline}</p>
      <p class="mt-4 leading-relaxed text-muted prose-readable">
        {category.description}
      </p>
    </header>

    <section aria-labelledby="cities-heading" class="mt-12">
      <h2 id="cities-heading" class="text-2xl font-bold text-ink">
        Choose your city
      </h2>

      {
        dedicated.length > 0 && (
          <ul class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {dedicated.map((entry) => (
              <li>
                <a
                  href={cityPath(category, entry.city)}
                  class="block h-full rounded-card border border-line bg-surface p-5 transition-colors hover:border-brand hover:bg-brand-soft/30"
                >
                  <span class="text-lg font-semibold text-ink">
                    {entry.city.city}, {entry.city.stateAbbr}
                  </span>
                  <span class="mt-1 block text-sm text-muted">
                    {entry.count} {entry.count === 1 ? 'listing' : 'listings'} →
                  </span>
                </a>
              </li>
            ))}
          </ul>
        )
      }

      {
        hubOnly.length > 0 && (
          <div class="mt-8">
            <h3 class="text-sm font-semibold text-ink">
              Also available in these cities
            </h3>
            <p class="mt-1 text-sm text-muted">
              Listed on each city's hub until it reaches a full page of its own.
            </p>
            <ul class="mt-3 flex flex-wrap gap-2">
              {hubOnly.map((entry) => (
                <li>
                  <a
                    href={cityHubPath(entry.city)}
                    class="inline-block rounded-full border border-line bg-surface px-3 py-1 text-sm text-muted transition-colors hover:border-brand hover:text-brand-strong"
                  >
                    {entry.city.city}, {entry.city.stateAbbr} ({entry.count})
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      {
        entries.length === 0 && (
          <p class="mt-6 max-w-2xl rounded-card border border-line bg-surface p-6 text-muted">
            We're still gathering listings for this category. Cities appear here
            automatically once they have data — check back soon.
          </p>
        )
      }
    </section>

    <div class="mt-16 max-w-3xl">
      <Faq faqs={category.faqs} />
    </div>

    <section class="mt-14 max-w-3xl rounded-card bg-brand-soft/40 p-6 sm:p-8">
      <h2 class="text-xl font-bold text-ink">How these listings are chosen</h2>
      <p class="mt-3 leading-relaxed text-muted prose-readable">
        Every place is reviewed against a written checklist before it's published,
        and each listing shows the date it was last checked. Read our full process
        on the{' '}
        <a class="link-underline font-medium text-brand-strong" href="/how-we-verify/">
          How We Verify
        </a>{' '}
        page.
      </p>
    </section>
  </div>
</BaseLayout>
